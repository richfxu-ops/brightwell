{
  "name": "brightwell",
  "version": "0.1.0",
  "description": "Brightwell — a roguelike economy deckbuilder set in the land of Roundelay (engine + content)",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:toy": "node scripts/build-toy.mjs",
    "lint": "biome lint",
    "lint:fix": "biome check --write",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
